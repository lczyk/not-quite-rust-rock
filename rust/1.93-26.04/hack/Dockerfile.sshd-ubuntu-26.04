# ubuntu 26.04 with openssh-server installed

# Build image for arm64 with:
#   docker build -t sshd-ubuntu-26.04-arm64 -f hack/Dockerfile.sshd-ubuntu-26.04 --platform linux/arm64 .
# Build image for amd64 with:
#   docker build -t sshd-ubuntu-26.04-amd64 -f hack/Dockerfile.sshd-ubuntu-26.04 --platform linux/amd64 .

FROM ubuntu:26.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y openssh-server && \
    mkdir /var/run/sshd || true && \
    echo 'root:ubuntu' | chpasswd && \
    echo "PermitRootLogin yes" >> /etc/ssh/sshd_config && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# when we log in through spread, we expect these to be present
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y curl wget git jq file && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# we expect to be able to run with sudo
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y sudo && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# install docker client for docker-in-docker usage
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io skopeo && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
